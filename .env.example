# ======================================
# LEXCORA FRONTEND ENVIRONMENT VARIABLES
# ======================================
# Copy this file to .env.local and fill in the values.
# NEXT_PUBLIC_* variables are inlined into the browser bundle at build time.
# Never put secrets or private keys in NEXT_PUBLIC_* variables.

# ========== API CONFIGURATION ==========
# Backend API base URL — REQUIRED.
# Development : http://localhost:8080/api
# Production  : https://lexcora-backend.vercel.app/api
#
# Must be set in Vercel → Project Settings → Environment Variables.
# axiosInstance will throw at build time if this is missing.
NEXT_PUBLIC_API_BASE_URL=https://lexcora-backend.vercel.app/api

# ========== APPLICATION ENVIRONMENT ==========
# Signals the runtime context to client-side code.
# Accepted values: development | staging | production
NEXT_PUBLIC_APP_ENV=production

# ========== ANALYTICS / TELEMETRY ==========
# Opt out of Next.js anonymous telemetry collection.
# This is also set in vercel.json → env so it applies during the Vercel build.
NEXT_TELEMETRY_DISABLED=1
