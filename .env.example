# ======================================
# LEXCORA FRONTEND ENVIRONMENT VARIABLES
# ======================================
# Copy this file to .env.local and update with actual values
# Note: NEXT_PUBLIC_* variables are exposed to the browser

# ========== API CONFIGURATION ==========
# Backend API base URL
# For development: http://localhost:8080/api
# For production: https://lexcora-backend.vercel.app/api
NEXT_PUBLIC_API_BASE_URL=https://lexcora-backend.vercel.app/api

# ========== NEXT.JS CONFIGURATION ==========
# Framework will be auto-detected by Vercel
NEXT_PUBLIC_APP_ENV=production
